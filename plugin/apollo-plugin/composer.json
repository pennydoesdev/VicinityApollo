{
  "name": "apollo/serve",
  "description": "Apollo — business-logic companion plugin for the Apollo theme.",
  "type": "wordpress-plugin",
  "license": "proprietary",
  "require": {
    "php": ">=8.3"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1",
    "phpstan/phpstan": "^1.11",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "phpunit/phpunit": "^10.5",
    "10up/wp_mock": "^1.0"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "autoload": {
    "psr-4": {
      "Apollo\\Serve\\": "includes/"
    }
  },
  "scripts": {
    "lint":  "phpcs --standard=WordPress-Extra --extensions=php -p -n .",
    "stan":  "phpstan analyse --level=6 --memory-limit=1G .",
    "test":  "phpunit --testdox"
  }
}
